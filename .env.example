# ============================================================
#  H1 Scope Watcher — Environment Variable Overrides
#
#  Copy this file to .env and fill in your secrets.
#  Load it with: source .env  OR  use a tool like direnv.
#
#  All values here override their counterparts in config.yaml.
#  Using env vars is the recommended approach for secrets so
#  they are never accidentally committed to version control.
# ============================================================

# HackerOne API credentials
H1_USERNAME=your_h1_username
H1_API_TOKEN=your_h1_api_token

# Discord webhook (leave blank to disable)
DISCORD_WEBHOOK_URL=

# Telegram bot (both values required to enable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Slack webhook (leave blank to disable)
SLACK_WEBHOOK_URL=

# Optional overrides
# CHECK_INTERVAL_MINUTES=30
# LOG_LEVEL=INFO
# STORAGE_PATH=snapshots
